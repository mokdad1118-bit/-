{
  "name": "adora-ecommerce-system",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npm run build:css && npm run build:css:admin",
    "lint": "eslint . --ext .js,.cjs",
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./tailwind.bundle.css --minify",
    "build:css:admin": "tailwindcss -i ./tailwind.input.css -o ./tailwind.admin.bundle.css --minify -c ./tailwind.admin.config.js",
    "build:netlify": "node scripts/write-adora-config.cjs",
    "migrate:sqlite-to-pg": "node scripts/migrate-sqlite-to-pg.cjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "redis": "^5.11.0",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3",
    "tailwindcss": "^3.4.17",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^6.4.0",
    "eslint": "^8.57.0",
    "sqlite3": "^5.1.7"
  }
}
