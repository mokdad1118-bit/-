# انسخ إلى .env محلياً:  copy .env.example .env
# على Render: لا ترفع .env — عيّن نفس المتغيرات في Environment (Dashboard).

NODE_ENV=development

# المنفذ (عادة 3000 داخل السيرفر، و80/443 أمام Nginx)
PORT=3000

# عنوان واجهة الـ PWA (نفس نطاق Netlify/adoraphoto.com حيث يُقدَّم sw.js والمجلد /icons/)
# يُستخدم في حمولة Web Push؛ بدونها ما زال sw.js يحوّل /icons/* لروابط مطلقة (مهم لـ iOS).
PUBLIC_URL=https://example.com

# --- مطلوب على الإنتاج (Render إلخ) ---
# سر توقيع JWT — في الإنتاج استخدم سلسلة عشوائية طويلة (مثلاً 64 حرفاً)
# لتوليد سريع:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# رابط الواجهة الأمامية (Netlify أو نطاقك) — CORS و Socket.io
# يجب أن يبدأ بـ https:// (مثال: https://adoraphoto.com) — بدون / في النهاية؛ عدة نطاقات مفصولة بفاصلة
# إذا تركتها فارغة: يُسمح بأي أصل (مناسب للتطوير فقط — لا يُنصح للإنتاج)
CORS_ORIGIN=

# اختياري: إذا أردت قيد Socket.io بنطاق مختلف عن REST
# SOCKET_CORS_ORIGIN=

# اختياري: Redis لمزامنة Socket.IO بين أكثر من نسخة خادم (Render عند Instance Count > 1).
# بدون Redis مع عدة نسخ، طلبات polling قد تعيد 400 (Session ID unknown).
# REDIS_URL=redis://default:PASSWORD@HOST:6379

# رابط PostgreSQL — مطلوب لتشغيل السيرفر (محلياً أو على Render).
# على Render: اربط قاعدة PostgreSQL بالـ Web Service أو انسخ External Database URL يدوياً.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
#
# اتصال محلي بدون SSL أحياناً: DATABASE_SSL=false
# DATABASE_SSL=false

# رابط متجر التطبيق (يُعرض للزوار عند الحاجة)
ADORA_APP_DOWNLOAD_URL=

# --- تسجيل سريع Google / Apple (اختياري) — يُعرض زر الدخول في الواجهة عند التعيين ---
# Google: معرّف عميل OAuth 2.0 من Google Cloud Console (نوع Web application).
# يمكن عدة معرفات مفصولة بمسافة أو فاصلة (مثلاً ويب + Android).
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
#
# Apple: Services ID من Apple Developer (Sign in with Apple) — نفس الـ Client ID في JS.
# APPLE_CLIENT_ID=com.example.app.web
# عنوان إعادة التوجيه المسجّل عند Apple (غالباً أصل الموقع مثل https://yourapp.netlify.app)
# APPLE_OAUTH_REDIRECT_URI=https://yourapp.netlify.app

# --- بريد رموز التحقق OTP (Resend) — التسجيل ونسيت كلمة المرور ---
# أنشئ مفتاحاً من https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxx
# في الإنتاج (مثل Render): عيّن عنوان مرسل من نطاق موثّق في https://resend.com/domains
# مثال: RESEND_FROM="Adora <otp@yourdomain.com>"
# أو: EMAIL_FROM=otp@yourdomain.com
# RESEND_FROM=
# EMAIL_FROM=
# اختياري: ملح إضافي لهاش رمز OTP على الخادم (افتراضياً يُستخدم JWT_SECRET)
# OTP_PEPPER=

# --- Cloudinary (مطلوب لرفع الصور من لوحة التحكم — لا تخزين على السيرفر) ---
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# أو:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=adora

# --- Web Push (إشعارات الجوال / PWA) — اختياري ---
# توليد مفاتيح:  npx web-push generate-vapid-keys
# انسخ Public / Private هنا. بدونها: الإشعارات داخل التطبيق + Toast فقط.
# VAPID_CONTACT_EMAIL=mailto:you@example.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
