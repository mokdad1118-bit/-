# انسخ إلى .env محلياً:  copy .env.example .env
# على Render: لا ترفع .env — عيّن نفس المتغيرات في Environment (Dashboard).

NODE_ENV=development

# المنفذ (عادة 3000 داخل السيرفر، و80/443 أمام Nginx)
PORT=3000

# عنوان الموقع العلني (للتسجيل في السجلات فقط — اضبطه على https://نطاقك.com)
PUBLIC_URL=https://example.com

# --- مطلوب على الإنتاج (Render إلخ) ---
# سر توقيع JWT — في الإنتاج استخدم سلسلة عشوائية طويلة (مثلاً 64 حرفاً)
# لتوليد سريع:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# رابط الواجهة الأمامية (Netlify) — CORS و Socket.io
# مثال: https://your-site.netlify.app  (بدون / في النهاية، يمكن أكثر من رابط مفصول بفاصلة)
# إذا تركتها فارغة: يُسمح بأي أصل (مناسب للتطوير فقط — لا يُنصح للإنتاج)
CORS_ORIGIN=

# اختياري: إذا أردت قيد Socket.io بنطاق مختلف عن REST
# SOCKET_CORS_ORIGIN=

# رابط PostgreSQL — مطلوب لتشغيل السيرفر (محلياً أو على Render).
# على Render: اربط قاعدة PostgreSQL بالـ Web Service أو انسخ External Database URL يدوياً.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
#
# اتصال محلي بدون SSL أحياناً: DATABASE_SSL=false
# DATABASE_SSL=false

# رابط متجر التطبيق (يُعرض للزوار عند الحاجة)
ADORA_APP_DOWNLOAD_URL=

# --- Cloudinary (رفع الصور للإنتاج — يُنصح على Render) ---
# إما ضع رابط واحد من لوحة Cloudinary:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# أو الثلاثة منفصلة:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# مجلد افتراضي على Cloudinary: adora (غيّره بـ CLOUDINARY_FOLDER=my_folder)
# CLOUDINARY_FOLDER=adora

# --- Web Push (إشعارات الجوال / PWA) — اختياري ---
# توليد مفاتيح:  npx web-push generate-vapid-keys
# انسخ Public / Private هنا. بدونها: الإشعارات داخل التطبيق + Toast فقط.
# VAPID_CONTACT_EMAIL=mailto:you@example.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
